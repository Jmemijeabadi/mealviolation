# Optional diagnostic Secrets for Oracle Labor Management.
# The Streamlit dashboard does not require or read these credentials.

[oracle_labor]
soap_url = "https://YOUR-HOST/ws/mylabor"
wsdl_url = "https://YOUR-HOST/ws/mylabor?wsdl"
rest_base_url = "https://YOUR-HOST/rest/services"
api_token = "YOUR_LABOR_API_TOKEN"
password = "YOUR_ROTATED_LABOR_PASSWORD"
timeout_seconds = 45
verify_ssl = true
