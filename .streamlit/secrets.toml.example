# Streamlit application Secrets — Business Intelligence API only.
# Copy locally to .streamlit/secrets.toml or paste this section into
# Streamlit Community Cloud > App settings > Secrets.

[oracle_bi]
auth_server = "https://YOUR-AUTHENTICATION-SERVER"
application_server = "https://YOUR-APPLICATION-SERVER"
org_identifier = "YOUR_ENTERPRISE_SHORT_NAME"
client_id = "YOUR_BUSINESS_INTELLIGENCE_API_CLIENT_ID"
username = "YOUR_BUSINESS_INTELLIGENCE_API_ACCOUNT"
password = "YOUR_ROTATED_BI_PASSWORD"
application_name = "Meal Compliance Dashboard"
timeout_seconds = 45
verify_ssl = true
